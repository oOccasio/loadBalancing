{
  "title": "Adaptive Load Balancer",
  "uid": "adaptive-lb",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-5m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "RPS (Requests per Second)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "alb_rps",
          "legendFormat": "RPS"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "title": "Latency (avg & p95)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "alb_avg_latency_ms",
          "legendFormat": "avg latency"
        },
        {
          "datasource": "Prometheus",
          "expr": "alb_p95_latency_ms",
          "legendFormat": "p95 latency"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 3,
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 7 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "alb_error_rate * 100",
          "legendFormat": "Error Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Active Connections per Server",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 7 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "alb_server_connections",
          "legendFormat": "{{server}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 5,
      "title": "Algorithm Switches",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 7 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "alb_algorithm_switches_total",
          "legendFormat": "Total Switches"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "purple" }
        }
      }
    },
    {
      "id": 6,
      "title": "Current Algorithm",
      "type": "stat",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 5 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "alb_algorithm == 1",
          "legendFormat": "{{algorithm}}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "name",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "id": 7,
      "title": "Current Traffic State",
      "type": "stat",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 5 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "alb_traffic_state == 1",
          "legendFormat": "{{state}}"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "textMode": "name",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      }
    }
  ]
}
